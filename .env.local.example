# ─────────────────────────────────────────────────────────────
# Educando na Rede — variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores
# ─────────────────────────────────────────────────────────────

# Chave de API do Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Email que receberá os contatos do formulário
CONTACT_EMAIL=seuemail@exemplo.com

# ATENÇÃO: para usar um remetente personalizado (ex: contato@seudominio.com.br),
# o domínio precisa ser verificado no painel do Resend.
# Enquanto não verificado, use o remetente padrão: onboarding@resend.dev
